# Required
ANTHROPIC_API_KEY=sk-ant-...

# DataMind API key (for MCP stdio mode)
DATAMIND_API_KEY=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASIC_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_SUCCESS_URL=https://datamind-api.kelnix.org/success
STRIPE_CANCEL_URL=https://datamind-api.kelnix.org/cancel

# Optional: Stripe Tax
STRIPE_TAX_ENABLED=false
STRIPE_COLLECT_ADDRESS=false

# Crypto payments (NOWPayments)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
CRYPTO_IPN_CALLBACK_URL=https://datamind-api.kelnix.org/billing/crypto_ipn

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379/1

# ChromaDB (optional, for vector search)
CHROMA_PERSIST_DIR=./chroma_data

# Legacy API keys (comma-separated, for testing)
API_KEYS=
